<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MedTracker</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark top-navbar">
        <div class="container-fluid px-4">
            <a class="navbar-brand d-flex align-items-center gap-2"
               asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-heart-pulse"></i>
                <span>MedTracker</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto ms-4">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="fa-solid fa-gauge me-1"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Devices" asp-action="Index">
                            <i class="fa-solid fa-stethoscope me-1"></i>Devices
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Incidents" asp-action="Index">
                            <i class="fa-solid fa-triangle-exclamation me-1"></i>Incidents
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="MaintenanceActions" asp-action="Index">
                            <i class="fa-solid fa-wrench me-1"></i>Maintenance
                        </a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-3">
                    <span class="text-white-50 small">
                        <i class="fa-regular fa-clock me-1"></i>
                        <span id="currentTime"></span>
                    </span>
                    <div class="vr bg-white opacity-25"></div>
                    <span class="text-white small">
                        <i class="fa-solid fa-user-nurse me-1"></i>
                        Gabriela Nicacio Lima
                    </span>
                </div>
            </div>
        </div>
    </nav>

    <!-- Page Content -->
    <div class="page-wrapper">
        <main class="main-content">
            <!-- Page Header Bar -->
            <div class="page-header-bar">
                <div class="container-fluid px-4">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            <li class="breadcrumb-item">
                                <a asp-controller="Home" asp-action="Index">
                                    <i class="fa-solid fa-house me-1"></i>Home
                                </a>
                            </li>
                            <li class="breadcrumb-item active">@ViewData["Title"]</li>
                        </ol>
                    </nav>
                </div>
            </div>

            <!-- Main Body -->
            <div class="container-fluid px-4 py-4">
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- Footer -->
    <footer class="site-footer">
        <div class="container-fluid px-4">
            <div class="d-flex justify-content-between align-items-center">
                <span>
                    <i class="fa-solid fa-heart-pulse me-1"></i>
                    MedTracker &copy; 2026
                </span>
                <span>Final Year Project — Gabriela Nicacio Lima</span>
                <span class="text-muted small">
                    Medical Device Maintenance System
                </span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Live clock
        function updateTime() {
            const now = new Date();
            document.getElementById('currentTime').textContent =
                now.toLocaleTimeString('en-IE', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        }
        updateTime();
        setInterval(updateTime, 1000);

        // Active nav link highlight
        document.querySelectorAll('.nav-link').forEach(link => {
            if (link.href === window.location.href) {
                link.classList.add('active');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>