@model MedicalDeviceMaintenance.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - MedTracker</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body style="background: linear-gradient(135deg, #1a5276 0%, #2e86c1 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center;">

    <div style="background: #fff; border-radius: 16px; box-shadow: 0 20px 60px rgba(0,0,0,0.2); padding: 2.5rem; width: 100%; max-width: 420px;">

        <div class="text-center mb-4">
            <i class="fa-solid fa-heart-pulse fa-3x" style="color: #e74c3c;"></i>
            <h2 style="color: #1a5276; font-weight: 700;" class="mt-2">Create Account</h2>
            <p class="text-muted small">New accounts are created as Viewer by default</p>
        </div>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-bold">Email</label>
                <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-bold">Password</label>
                <input asp-for="Password" class="form-control" placeholder="Minimum 6 characters" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label fw-bold">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat your password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div class="alert alert-warning py-2 mb-3 small">
                <i class="fa-solid fa-circle-info me-1"></i>
                New accounts start with <strong>Viewer</strong> role.
                Contact an Admin to change your role.
            </div>

            <button type="submit" class="btn w-100 mb-3 text-white fw-bold"
                    style="background: linear-gradient(135deg, #1e8449, #27ae60); border: none; padding: 0.75rem; border-radius: 8px;">
                <i class="fa-solid fa-user-plus me-2"></i>Create Account
            </button>

            <div class="text-center">
                <a asp-action="Login" class="text-decoration-none" style="color: #2e86c1;">
                    <i class="fa-solid fa-arrow-left me-1"></i>Back to Login
                </a>
            </div>
        </form>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>