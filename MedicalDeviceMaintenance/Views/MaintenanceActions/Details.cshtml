@model MedicalDeviceMaintenance.Models.MaintenanceAction
@{
    ViewData["Title"] = "Maintenance Action Details";
}

<h1>Maintenance Action Details</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <h4>Action Information</h4>
        <dl class="row">
            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Incident)
            </dt>
            <dd class="col-sm-8">
                <a asp-controller="Incidents" asp-action="Details"
                   asp-route-id="@Model.IncidentId">
                    @Html.DisplayFor(model => model.Incident.Title)
                </a>
            </dd>

            <dt class="col-sm-4">Device</dt>
            <dd class="col-sm-8">
                <a asp-controller="Devices" asp-action="Details"
                   asp-route-id="@Model.Incident.DeviceId">
                    @Html.DisplayFor(model => model.Incident.Device.Name)
                </a>
            </dd>

            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.ActionTaken)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.ActionTaken)
            </dd>

            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.TechnicianName)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.TechnicianName)
            </dd>

            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.ActionDate)
            </dt>
            <dd class="col-sm-8">
                @Html.DisplayFor(model => model.ActionDate)
            </dd>

            <dt class="col-sm-4">
                @Html.DisplayNameFor(model => model.Notes)
            </dt>
            <dd class="col-sm-8">
                @(Model.Notes ?? "No notes recorded")
            </dd>
        </dl>

        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model?.Id"
               class="btn btn-primary me-2">Edit</a>
            <a asp-action="Index"
               class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>