@model IEnumerable<MedicalDeviceMaintenance.Models.Incident>
@{
    ViewData["Title"] = "Incidents";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Incidents</h1>
    <a asp-action="Create" class="btn btn-primary">+ Report New Incident</a>
</div>

<hr />

@if (!Model.Any())
{
    <div class="alert alert-info">
        No incidents recorded. Click "Report New Incident" to get started.
    </div>
}
else
{
    <table class="table table-striped table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Title)</th>
                <th>@Html.DisplayNameFor(model => model.Description)</th>
                <th>@Html.DisplayNameFor(model => model.Severity)</th>
                <th>@Html.DisplayNameFor(model => model.Status)</th>
                <th>@Html.DisplayNameFor(model => model.DateReported)</th>
                <th>Device</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Title)</td>
                    <td>
                        @if (item.Description.Length > 50)
                        {
                            @item.Description.Substring(0, 50)

                            <text>...</text>
                        }
                        else
                        {
                            @item.Description
                        }
                    </td>
                    <td>
                        <span class="badge @(item.Severity == "Critical" || item.Severity == "High" ? "bg-danger" :
                                             item.Severity == "Medium" ? "bg-warning text-dark" :
                                             "bg-info")">
                            @item.Severity
                        </span>
                    </td>
                    <td>
                        <span class="badge @(item.Status == "Open" ? "bg-danger" :
                                             item.Status == "In Progress" ? "bg-warning text-dark" :
                                             "bg-success")">
                            @item.Status
                        </span>
                    </td>
                    <td>@item.DateReported.ToShortDateString()</td>
                    <td>
                        <a asp-controller="Devices" asp-action="Details"
                           asp-route-id="@item.DeviceId">
                            @Html.DisplayFor(modelItem => item.Device.Name)
                        </a>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id"
                           class="btn btn-sm btn-info me-1">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn btn-sm btn-warning me-1">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id"
                           class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}