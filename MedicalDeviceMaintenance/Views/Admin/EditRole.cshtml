@model MedicalDeviceMaintenance.Models.EditRoleViewModel
@{
    ViewData["Title"] = "Change User Role";
}

<h1>Change User Role</h1>
<hr />

<div class="row">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header bg-white">
                <i class="fa-solid fa-user-pen me-2 text-warning"></i>
                Edit Role for @Model.Email
            </div>
            <div class="card-body">
                <form asp-action="EditRole" method="post">
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="Email" />

                    <div class="form-group mb-3">
                        <label class="control-label fw-bold">Select New Role</label>
                        <select asp-for="CurrentRole" class="form-control">
                            @foreach (var role in Model.AllRoles)
                            {
                                <option value="@role"
                                        selected="@(role == Model.CurrentRole)">
                                    @role
                                </option>
                            }
                        </select>
                    </div>

                    <div class="mt-3">
                        <input type="submit" value="Save Role"
                               class="btn btn-primary me-2" />
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>